{
  "name": "vue3-simple-dropzone",
  "version": "1.2.1",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/vue3-simple-dropzone.umd.js",
  "module": "./dist/vue3-simple-dropzone.es.js",
  "exports": {
    ".": {
      "import": "./dist/vue3-simple-dropzone.es.js",
      "require": "./dist/vue3-simple-dropzone.umd.js"
    },
    "./style.css": "./dist/vue3-simple-dropzone.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "postbuild": "node bin/bundler.js",
    "preview": "vite preview",
    "publish:npm": "npm run build && npm publish dist/"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "~5.7.0",
    "vite": "^8.0.3",
    "vue-tsc": "^2.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmabid/vue3-simple-dropzone"
  },
  "homepage": "https://github.com/fmabid/vue3-simple-dropzone",
  "bugs": {
    "url": "https://github.com/fmabid/vue3-simple-dropzone/issues"
  },
  "keywords": [
    "vue3",
    "dropzone",
    "uploader"
  ]
}
